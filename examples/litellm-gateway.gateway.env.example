# LiteLLM Gateway non-secret network environment example.
# The setup and bridge scripts write this shape to /opt/litellm-gateway/gateway.env.
# Example-only values below are placeholders; detect or choose values for your network.

LITELLM_HOST_IP=192.168.1.50
LITELLM_PORT=4000
TRUSTED_CLIENT_CIDR=192.168.1.0/24
OLLAMA_BRIDGE_API_BASE=http://172.30.0.1:11434
DOCKER_LITELLM_SUBNET=172.30.0.0/16
OLLAMA_HOST_BIND=0.0.0.0:11434
ZEROCLAW_HOST_IP=
BIND_ADDR=0.0.0.0
COMPOSE_PROJECT_NAME=litellm-gateway
LITELLM_IMAGE=ghcr.io/berriai/litellm-non_root:v1.83.3-stable.patch.2
POSTGRES_IMAGE=postgres:16-bookworm
LITELLM_READ_ONLY=false
