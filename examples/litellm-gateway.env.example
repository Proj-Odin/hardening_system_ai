# LiteLLM Gateway environment example.
# Copy values into /opt/litellm-gateway/.env using the setup script.
# Do not put real secrets in this repo.

POSTGRES_USER=litellm
POSTGRES_DB=litellm
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM
DATABASE_URL=postgresql://litellm:REPLACE_WITH_STRONG_RANDOM@postgres:5432/litellm

LITELLM_MASTER_KEY=sk-REPLACE_WITH_STRONG_RANDOM
LITELLM_SALT_KEY=REPLACE_WITH_STRONG_RANDOM

# Use a dedicated, low-budget provider key for this gateway.
# Do not use your personal master account key.
OPENROUTER_API_KEY=REPLACE_WITH_LOW_BUDGET_OPENROUTER_KEY

BIND_ADDR=0.0.0.0
LITELLM_PORT=4000
TRUSTED_CIDR=172.16.172.0/24

LITELLM_IMAGE=ghcr.io/berriai/litellm-non_root:v1.83.0-stable
POSTGRES_IMAGE=postgres:16-bookworm
LITELLM_READ_ONLY=true
COMPOSE_PROJECT_NAME=litellm-gateway
