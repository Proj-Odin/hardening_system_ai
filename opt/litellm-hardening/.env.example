# Copy this file to /etc/litellm-hardening/litellm.env and edit there.
# This file is sourced by bash and also read by compose/systemd.

DEPLOYMENT_MODE=auto
CONTAINER_RUNTIME=docker
COMPOSE_PROJECT_NAME=litellm
DRY_RUN=false

LITELLM_IMAGE_REPO=ghcr.io/berriai/litellm
LITELLM_IMAGE_TAG=v1.83.3-stable.patch.1
LITELLM_IMAGE_DIGEST=sha256:fc9c0cc5cdfd8bb9a47c51e20a56235b56cf55e93f8c1a880e30a5b3b0a2fb67
LITELLM_COSIGN_KEY_FILE=/opt/litellm-hardening/cosign.pub
LITELLM_SIGNING_KEY_COMMIT=0112e53046018d726492c814b3644b7d376029d0

LITELLM_EXPECTED_PYTHON_VERSION=1.83.9
ALLOW_VENV_FALLBACK=false
VENV_PYTHON_BIN=/usr/bin/python3
VENV_DIR=/opt/litellm-venv
LITELLM_REQUIREMENTS_LOCK=/opt/litellm-hardening/venv/requirements.lock

LITELLM_CONFIG_FILE=/opt/litellm-hardening/litellm_config.yaml
BACKUP_ROOT=/var/backups/litellm-hardening
STATE_ROOT=/var/lib/litellm-hardening
DATA_ROOT=/var/lib/litellm

LITELLM_BIND_ADDRESS=127.0.0.1
LITELLM_BIND_PORT=4000
LITELLM_STAGING_BIND_PORT=4400
ALLOW_PUBLIC_BIND=false
ALLOW_NONPRIVATE_BACKEND_HOSTS=false

LITELLM_RUNTIME_UID=101
LITELLM_RUNTIME_GID=101
LITELLM_NUM_WORKERS=2
LITELLM_NON_ROOT=true

ENABLE_UI=false
ENABLE_NGINX=false
SERVER_NAME=litellm.example.internal
TLS_CERT_FILE=/etc/ssl/certs/litellm.crt
TLS_KEY_FILE=/etc/ssl/private/litellm.key

USE_PRISMA_MIGRATE=True
LITELLM_MODE=PRODUCTION
LITELLM_LOG=ERROR
ALLOW_REQUESTS_ON_DB_UNAVAILABLE=false
STORE_MODEL_IN_DB=true
STORE_PROMPTS_IN_SPEND_LOGS=false
DISABLE_SPEND_LOGS=true
DISABLE_END_USER_COST_TRACKING=true
DISABLE_ERROR_LOGS=true
SEPARATE_HEALTH_APP=0
SEPARATE_HEALTH_PORT=4001
MAX_IMAGE_URL_DOWNLOAD_SIZE_MB=0

LITELLM_MIGRATION_DIR=/var/lib/litellm/migrations
PRISMA_BINARY_CACHE_DIR=/var/lib/litellm/cache/prisma
XDG_CACHE_HOME=/var/lib/litellm/cache
LITELLM_UI_PATH=/var/lib/litellm/ui
LITELLM_ASSETS_PATH=/var/lib/litellm/assets

DATABASE_URL=postgresql://litellm:change-me@127.0.0.1:5432/litellm
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Must start with sk- and must not be rotated automatically.
LITELLM_MASTER_KEY=

# Leave blank only if there are no existing LiteLLM models or encrypted credentials yet.
LITELLM_SALT_KEY=
AUTO_GENERATE_SALT_KEY=true

# If set, the toolkit prefers this service for interim in-place hardening.
LEGACY_SERVICE_NAME=
INTERIM_RESTART_SERVICE=true
ROLLBACK_RESTORE_DATABASE=false

# Add provider credentials below as needed.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
SLACK_WEBHOOK_URL=
