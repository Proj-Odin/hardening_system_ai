+        assert_eq!(sanitized.text, "remember the blue notebook");
+        assert!(!sanitized.had_media);
+    }
+
+    #[test]
+    fn memory_config_defaults_cover_sanitization_config() {
+        let memory = MemoryConfig::default();
+        let config = EmbeddingSanitizationConfig::from(&memory);
+
+        assert!(!config.embed_media_placeholders);
+        assert!(config.embed_assistant_image_summaries);
+        assert!(config.skip_embedding_for_image_messages);
+        assert_eq!(config.max_text_chars, DEFAULT_EMBEDDING_TEXT_MAX_CHARS);
+    }
+
+    #[test]
+    fn image_only_message_is_skipped_by_default() {
+        let sanitized = sanitize_for_embedding_with_config(
+            "[IMAGE:/tmp/telegram/photo.jpg]",
+            &EmbeddingSanitizationConfig::default(),
+        );
+        assert!(sanitized.had_media);
+        assert!(sanitized.text.is_empty());
+    }
+
+    #[test]
+    fn image_only_message_can_embed_placeholder() {
+        let config = EmbeddingSanitizationConfig {
+            embed_media_placeholders: true,
+            ..EmbeddingSanitizationConfig::default()
+        };
+        let sanitized = sanitize_for_embedding_with_config("[IMAGE:/tmp/photo.jpg]", &config);
+        assert_eq!(sanitized.text, "[image attached]");
+        assert!(sanitized.had_media);
+    }
+
+    #[test]
+    fn text_plus_image_keeps_text_only_by_default() {
+        let sanitized = sanitize_for_embedding_with_config(
+            "[IMAGE:/tmp/photo.jpg]\n\nThis is the valve label.",
+            &EmbeddingSanitizationConfig::default(),
+        );
+        assert_eq!(sanitized.text, "This is the valve label.");
+        assert!(sanitized.had_media);
+    }
+
+    #[test]
+    fn data_uri_and_base64_are_not_embedded() {
+        let input = format!(
+            "before [IMAGE:data:image/png;base64,{}] after",
+            "A".repeat(512)
+        );
+        let sanitized =
+            sanitize_for_embedding_with_config(&input, &EmbeddingSanitizationConfig::default());
+        assert_eq!(sanitized.text, "before after");
+        assert!(!sanitized.text.contains("base64"));
+        assert!(!sanitized.text.contains(&"A".repeat(80)));
+    }
+
+    #[test]
+    fn json_image_url_keeps_text_part_only() {
+        let input = r#"[
+            {"type":"text","text":"what is in this image?"},
+            {"type":"image_url","image_url":{"url":"data:image/png;base64,AAAA"}}
+        ]"#;
+        let sanitized =
+            sanitize_for_embedding_with_config(input, &EmbeddingSanitizationConfig::default());
+        assert_eq!(sanitized.text, "what is in this image?");
+        assert!(sanitized.had_media);
+        assert!(!sanitized.text.contains("image_url"));
+        assert!(!sanitized.text.contains("base64"));
+    }
+
+    #[test]
+    fn assistant_image_summary_fields_follow_config() {
+        let input = r#"{"image_summary":"Assistant identified serial number A17"}"#;
+        let sanitized =
+            sanitize_for_embedding_with_config(input, &EmbeddingSanitizationConfig::default());
+        assert_eq!(sanitized.text, "Assistant identified serial number A17");
+
+        let config = EmbeddingSanitizationConfig {
+            embed_assistant_image_summaries: false,
+            ..EmbeddingSanitizationConfig::default()
+        };
+        let sanitized = sanitize_for_embedding_with_config(input, &config);
+        assert!(sanitized.text.is_empty());
+    }
+
+    #[test]
+    fn telegram_caption_is_safe_text() {
+        let sanitized = sanitize_for_embedding_with_config(
+            "[IMAGE:/home/admin/.zeroclaw/workspace/telegram_files/photo.jpg]\n\nserial number A17",
+            &EmbeddingSanitizationConfig::default(),
+        );
+        assert_eq!(sanitized.text, "serial number A17");
+        assert!(sanitized.had_media);
+    }
+
+    #[test]
+    fn max_text_length_is_enforced_on_char_boundary() {
+        let config = EmbeddingSanitizationConfig {
+            max_text_chars: 4,
+            ..EmbeddingSanitizationConfig::default()
+        };
+        let sanitized = sanitize_for_embedding_with_config("ab\u{1F600}cd", &config);
+        assert_eq!(sanitized.text, "ab\u{1F600}c");
+    }
+}
