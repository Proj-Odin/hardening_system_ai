@@ -0,0 +1,491 @@
+use std::sync::LazyLock;
+
+use regex::Regex;
+use serde_json::Value;
+use zeroclaw_config::schema::MemoryConfig;
+
+pub const DEFAULT_EMBEDDING_TEXT_MAX_CHARS: usize = 8192;
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub struct EmbeddingSanitizationConfig {
+    pub embed_media_placeholders: bool,
+    pub skip_embedding_for_image_messages: bool,
+    pub embed_assistant_image_summaries: bool,
+    pub max_text_chars: usize,
+}
+
+impl Default for EmbeddingSanitizationConfig {
+    fn default() -> Self {
+        Self {
+            embed_media_placeholders: false,
+            skip_embedding_for_image_messages: true,
+            embed_assistant_image_summaries: true,
+            max_text_chars: DEFAULT_EMBEDDING_TEXT_MAX_CHARS,
+        }
+    }
+}
+
+impl From<&MemoryConfig> for EmbeddingSanitizationConfig {
+    fn from(config: &MemoryConfig) -> Self {
+        Self {
+            embed_media_placeholders: config.embed_media_placeholders,
+            skip_embedding_for_image_messages: config.skip_embedding_for_image_messages,
+            embed_assistant_image_summaries: config.embed_assistant_image_summaries,
+            max_text_chars: config.embedding_text_max_chars,
+        }
+    }
+}
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub struct SanitizedEmbeddingText {
+    pub text: String,
+    pub had_media: bool,
+}
+
+pub fn sanitize_for_embedding(message: &str) -> String {
+    sanitize_for_embedding_with_config(message, &EmbeddingSanitizationConfig::default()).text
+}
+
+pub fn sanitize_for_embedding_with_config(
+    message: &str,
+    config: &EmbeddingSanitizationConfig,
+) -> SanitizedEmbeddingText {
+    let mut had_media = false;
+    let trimmed = message.trim();
+
+    let mut text = if let Some(json_text) = sanitize_json_message(trimmed, config, &mut had_media) {
+        json_text
+    } else {
+        sanitize_plain_text(trimmed, config, &mut had_media)
+    };
+
+    text = normalize_embedding_text(&text);
+    if config.skip_embedding_for_image_messages && text.is_empty() && had_media {
+        return SanitizedEmbeddingText {
+            text: String::new(),
+            had_media,
+        };
+    }
+
+    SanitizedEmbeddingText {
+        text: truncate_to_chars(&text, config.max_text_chars),
+        had_media,
+    }
+}
+
+pub fn log_embedding_skip_if_media_only(sanitized: &SanitizedEmbeddingText) {
+    log_embedding_sanitization(sanitized);
+}
+
+pub fn log_embedding_sanitization(sanitized: &SanitizedEmbeddingText) {
+    tracing::debug!(
+        "Embedding sanitized text length: {}",
+        sanitized.text.chars().count()
+    );
+    if sanitized.had_media {
+        tracing::info!("Media payload removed from embedding copy");
+    }
+    if sanitized.had_media && sanitized.text.trim().is_empty() {
+        tracing::info!("Skipping embedding: no text content after media sanitization");
+    }
+}
+
+fn sanitize_json_message(
+    message: &str,
+    config: &EmbeddingSanitizationConfig,
+    had_media: &mut bool,
+) -> Option<String> {
+    if !(message.starts_with('{') || message.starts_with('[')) {
+        return None;
+    }
+
+    let value = serde_json::from_str::<Value>(message).ok()?;
+    let mut parts = Vec::new();
+    collect_json_text(&value, config, had_media, &mut parts);
+    Some(parts.join("\n"))
+}
+
+fn collect_json_text(
+    value: &Value,
+    config: &EmbeddingSanitizationConfig,
+    had_media: &mut bool,
+    parts: &mut Vec<String>,
+) {
+    match value {
+        Value::String(text) => {
+            let safe = sanitize_plain_text(text, config, had_media);
+            if !safe.trim().is_empty() {
+                parts.push(safe);
+            }
+        }
+        Value::Array(items) => {
+            for item in items {
+                collect_json_text(item, config, had_media, parts);
+            }
+        }
+        Value::Object(map) => {
+            let value_type = map
+                .get("type")
+                .and_then(Value::as_str)
+                .unwrap_or_default()
+                .to_ascii_lowercase();
+
+            if is_media_json_type(&value_type) || map.keys().any(|key| is_media_json_key(key)) {
+                *had_media = true;
+                if config.embed_media_placeholders {
+                    parts.push(media_placeholder_for_json(&value_type).to_string());
+                }
+            }
+
+            if value_type == "text" || value_type == "input_text" {
+                if let Some(text) = map.get("text").and_then(Value::as_str) {
+                    let safe = sanitize_plain_text(text, config, had_media);
+                    if !safe.trim().is_empty() {
+                        parts.push(safe);
+                    }
+                }
+                return;
+            }
+
+            for key in ["content", "text", "caption", "description", "transcript"] {
+                if let Some(child) = map.get(key) {
+                    collect_json_text(child, config, had_media, parts);
+                }
+            }
+            if config.embed_assistant_image_summaries {
+                for key in [
+                    "summary",
+                    "image_summary",
+                    "vision_summary",
+                    "assistant_image_summary",
+                    "ocr",
+                    "ocr_text",
+                ] {
+                    if let Some(child) = map.get(key) {
+                        collect_json_text(child, config, had_media, parts);
+                    }
+                }
+            }
+        }
+        Value::Null | Value::Bool(_) | Value::Number(_) => {}
+    }
+}
+
+fn is_media_json_type(value_type: &str) -> bool {
+    matches!(
+        value_type,
+        "image"
+            | "image_url"
+            | "input_image"
+            | "document"
+            | "file"
+            | "video"
+            | "audio"
+            | "voice"
+    )
+}
+
+fn is_media_json_key(key: &str) -> bool {
+    matches!(
+        key.to_ascii_lowercase().as_str(),
+        "image_url"
+            | "image"
+            | "images"
+            | "input_image"
+            | "file_data"
+            | "file_id"
+            | "base64"
+            | "data"
+            | "bytes"
+            | "raw"
+            | "telegram_file"
+            | "mime_type"
+            | "content_type"
+    )
+}
+
+fn media_placeholder_for_json(value_type: &str) -> &'static str {
+    match value_type {
+        "video" => "[video attached]",
+        "audio" | "voice" => "[audio attached]",
+        "document" | "file" => "[file attached]",
+        _ => "[image attached]",
+    }
+}
+
+fn sanitize_plain_text(
+    message: &str,
+    config: &EmbeddingSanitizationConfig,
+    had_media: &mut bool,
+) -> String {
+    let mut text = message.to_string();
+    text = strip_json_media_fields(&text, config, had_media);
+    text = strip_media_markers(&text, config, had_media);
+    text = strip_existing_media_placeholders(&text, config, had_media);
+    text = strip_data_uris(&text, had_media);
+    text = strip_long_base64_tokens(&text, had_media);
+    text
+}
+
+fn strip_media_markers(
+    text: &str,
+    config: &EmbeddingSanitizationConfig,
+    had_media: &mut bool,
+) -> String {
+    static RE: LazyLock<Regex> = LazyLock::new(|| {
+        Regex::new(r"(?is)\[(IMAGE|DOCUMENT|FILE|VIDEO|VOICE|AUDIO):[^\]]*\]").unwrap()
+    });
+
+    let mut saw = false;
+    let replaced = RE.replace_all(text, |captures: &regex::Captures<'_>| {
+        saw = true;
+        if config.embed_media_placeholders {
+            placeholder_for_marker(&captures[1]).to_string()
+        } else {
+            String::new()
+        }
+    });
+    if saw {
+        *had_media = true;
+    }
+    replaced.into_owned()
+}
+
+fn strip_existing_media_placeholders(
+    text: &str,
+    config: &EmbeddingSanitizationConfig,
+    had_media: &mut bool,
+) -> String {
+    static RE: LazyLock<Regex> = LazyLock::new(|| {
+        Regex::new(r"(?i)\[(?:image|photo|media|video|audio|voice|file|document) attached\]")
+            .unwrap()
+    });
+
+    let mut saw = false;
+    let replaced = RE.replace_all(text, |captures: &regex::Captures<'_>| {
+        saw = true;
+        if config.embed_media_placeholders {
+            captures[0].to_ascii_lowercase()
+        } else {
+            String::new()
+        }
+    });
+    if saw {
+        *had_media = true;
+    }
+    replaced.into_owned()
+}
+
+fn strip_data_uris(text: &str, had_media: &mut bool) -> String {
+    static RE: LazyLock<Regex> = LazyLock::new(|| {
+        Regex::new(r"(?i)data:[a-z0-9.+-]+/[a-z0-9.+-]+;base64,[a-z0-9+/=_-]+").unwrap()
+    });
+
+    if RE.is_match(text) {
+        *had_media = true;
+    }
+    RE.replace_all(text, "").into_owned()
+}
+
+fn strip_long_base64_tokens(text: &str, had_media: &mut bool) -> String {
+    static RE: LazyLock<Regex> =
+        LazyLock::new(|| Regex::new(r"\b[A-Za-z0-9+/]{160,}={0,2}\b").unwrap());
+
+    if RE.is_match(text) {
+        *had_media = true;
+    }
+    RE.replace_all(text, "").into_owned()
+}
+
+fn strip_json_media_fields(
+    text: &str,
+    config: &EmbeddingSanitizationConfig,
+    had_media: &mut bool,
+) -> String {
+    static IMAGE_URL_OBJECT_RE: LazyLock<Regex> = LazyLock::new(|| {
+        Regex::new(r#"(?is)"image_url"\s*:\s*\{[^{}]*(?:\{[^{}]*\}[^{}]*)*\}"#).unwrap()
+    });
+    static IMAGE_URL_STRING_RE: LazyLock<Regex> =
+        LazyLock::new(|| Regex::new(r#"(?is)"image_url"\s*:\s*"[^"]*""#).unwrap());
+    static BASE64_FIELD_RE: LazyLock<Regex> =
+        LazyLock::new(|| Regex::new(r#"(?is)"(?:base64|data|bytes|raw)"\s*:\s*"[^"]+""#).unwrap());
+
+    let replacement = if config.embed_media_placeholders {
+        "\"text\":\"[image attached]\""
+    } else {
+        ""
+    };
+
+    let mut output = text.to_string();
+    for re in [
+        &*IMAGE_URL_OBJECT_RE,
+        &*IMAGE_URL_STRING_RE,
+        &*BASE64_FIELD_RE,
+    ] {
+        if re.is_match(&output) {
+            *had_media = true;
+            output = re.replace_all(&output, replacement).into_owned();
+        }
+    }
+    output
+}
+
+fn placeholder_for_marker(marker: &str) -> &'static str {
+    match marker.to_ascii_uppercase().as_str() {
+        "VIDEO" => "[video attached]",
+        "VOICE" | "AUDIO" => "[audio attached]",
+        "DOCUMENT" | "FILE" => "[file attached]",
+        _ => "[image attached]",
+    }
+}
+
+fn normalize_embedding_text(text: &str) -> String {
+    let mut normalized = text.replace("\r\n", "\n").replace('\r', "\n");
+    static SPACE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r"[ \t]+").unwrap());
+    normalized = SPACE_RE.replace_all(&normalized, " ").into_owned();
+
+    let mut lines = Vec::new();
+    for line in normalized.lines() {
+        let trimmed = line.trim();
+        if trimmed.is_empty() {
+            if !lines.last().is_some_and(|line: &&str| line.is_empty()) {
+                lines.push("");
+            }
+        } else {
+            lines.push(trimmed);
+        }
+    }
+
+    while lines.last().is_some_and(|line| line.is_empty()) {
+        lines.pop();
+    }
+    lines.join("\n").trim().to_string()
+}
+
+fn truncate_to_chars(text: &str, max_chars: usize) -> String {
+    if max_chars == 0 {
+        return String::new();
+    }
+    if text.chars().count() <= max_chars {
+        return text.to_string();
+    }
+    text.chars().take(max_chars).collect()
+}
+
